@article{schneider_anodizingpore_2022,
	title = {Anodizing—{The} pore makes the difference},
	volume = {73},
	issn = {0947-5117, 1521-4176},
	url = {https://onlinelibrary.wiley.com/doi/10.1002/maco.202213324},
	doi = {10.1002/maco.202213324},
	abstract = {Abstract
            The presentation gives an insight into the fascinating world of anodizing as corrosion protection but also goes far beyond. Starting with an introduction to the formation of anodic oxide films and their characteristic features, the authors briefly outline the subject of pore nucleation and growth. The number, size, and shape of the pores essentially determine the properties and play a crucial role in the final application of the anodizing layers. The tailoring of pore design, considering the final application as well as the use of the porous oxide layers for subsequent functional modifications, is demonstrated by examples, exclusively developed in the working groups of the respective authors or in joint research projects, which were in part professionally accompanied and supported by the German Corrosion Society GfKORR e.V.},
	language = {en},
	number = {11},
	journal = {Materials and Corrosion},
	author = {Schneider, Michael and Fürbeth, Wolfram},
	month = nov,
	year = {2022},
	pages = {1752--1765},
}

@article{rozenblium_comprehensive_2024,
	title = {A {Comprehensive} {Study} of {Aluminum} {Anodization} in {Transition} {Modes}},
	volume = {17},
	issn = {1996-1944},
	url = {https://www.ncbi.nlm.nih.gov/pmc/articles/PMC11278022/},
	doi = {10.3390/ma17143438},
	abstract = {Anodization is a method to fabricate a tunable nanoporosity and thickness of alumina coating. This research is devoted to large-area hard anodization (HA), ultrahard anodization (UHA), and transitional modes. The phenomenon and challenges of UHA and the transition from HA are studied on large-area samples using linear-sweep voltammetry. The findings indicate that a uniform large-area thick coating can be achieved by utilizing pre-UHA modes. The study’s results indicate that UHA leads only to coatings with non-uniform thickness in large-area anodization. The peculiarities of pre-UHA are studied using different temperatures (0, 5, 10, and 15 °C) and processing times (1, 2, 4, 6, and 12 h) in a 0.3 M oxalic acid electrolyte. The current study shows the possibility for the fast growth of thick nanoporous alumina up to 235 ± 4 µm for only 12 h.},
	number = {14},
	journal = {Materials},
	author = {Rozenblium, Ilia and Yuferov, Yuliy and Borodianskiy, Konstantin},
	month = jul,
	year = {2024},
	pmid = {39063730},
	pmcid = {PMC11278022},
	pages = {3438},
}

